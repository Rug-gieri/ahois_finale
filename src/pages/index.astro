---
import Layout from '../layouts/Layout.astro'
import NavBar from '../components/NavBar.svelte'
import Hero from '../components/Hero.astro'
import FeatureLeft from '../components/FeatureLeft.astro'
import FeatureRight from '../components/FeatureRight.astro'
import Catalogo from '../components/Catalogo.svelte'
import CartDrawer from '../components/CartDrawer.svelte'
import Agenda from '../components/Agenda.astro'
import SobreArtesa from '../components/SobreArtesa.astro'
import Footer from '../components/Footer.astro'
---

<Layout>
  <NavBar client:load />
  <main>
    <Hero />
    <FeatureLeft />
    <FeatureRight />
    <Catalogo client:load />
    <Agenda />
    <SobreArtesa />
    <Footer />
  </main>
  <CartDrawer client:load />
</Layout>