---
interface Props {
  imageSrc?: string
  imageAlt?: string
}

const {
  imageSrc = '/images/cliente.png',
  imageAlt = 'Peças feitas à mão'
} = Astro.props

const items = [
  { title: 'O plástico satura', desc: 'Brinquedos industriais quebram, lotam o armário e viram lixo em semanas.' },
  { title: 'O amigurumi acolhe', desc: 'Cada peça é um companheiro exclusivo que não quebra, não precisa de bateria e dura gerações.' },
  { title: 'Presente com sentido', desc: 'Na era das telas, dê um amigo feito à mão. Ideal para quem quer presentear com amor.' },
  { title: 'Tradição viva', desc: 'Valorizamos a arte do crochê, o trabalho manual e a história que cada ponto carrega.' },
]
---

<section id="artesanato" class="flex flex-col md:flex-row" style="content-visibility: auto">
  <div class="w-full md:w-1/2 order-2 md:order-1">
    <img
      src={imageSrc}
      alt={imageAlt}
      class="w-full h-[50vh] md:h-screen object-cover"
      loading="lazy"
      decoding="async"
    />
  </div>

  <div class="w-full md:w-1/2 bg-bege p-10 md:p-16 flex flex-col justify-center min-h-[50vh] md:min-h-screen order-1 md:order-2">
    <h2 class="text-4xl md:text-5xl font-bold text-marrom-escuro leading-tight mb-10">
      Na era das telas, dê um<br/>amigo feito à mão.
    </h2>
    <ul class="space-y-6">
      {items.map((item) => (
        <li class="flex items-start gap-4 group">
          <span class="mt-2 w-3 h-3 rounded-full bg-marrom-escuro shrink-0 transition-all duration-300 group-hover:scale-150 group-hover:bg-marrom-claro" />
          <div>
            <span class="text-marrom-escuro text-xl font-bold">{item.title}</span>
            <span class="text-marrom-escuro/80 text-lg"> — {item.desc}</span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>