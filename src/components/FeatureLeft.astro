---
interface Props {
  imageSrc?: string
  imageAlt?: string
}

const {
  imageSrc = '/images/aboutimage.jpg',
  imageAlt = 'Materiais de alta qualidade'
} = Astro.props

const items = [
  { title: 'Estímulo tátil real', desc: 'Texturas e pontos que ativam o sistema sensorial da criança — a tela do celular jamais fará isso.' },
  { title: 'Imaginação sem limites', desc: 'Sem luzes nem sons prontos. A criança cria a voz, a história e o mundo do personagem.' },
  { title: 'Objeto de transição afetiva', desc: 'Retém o cheiro dos pais e da casa, gerando segurança e reduzindo a ansiedade de separação.' },
  { title: 'Segurança total', desc: 'Linha 100% algodão e olhos com trava. Seguro para morder, lavar e abraçar sem medo.' },
]
---

<section id="materiais" class="flex flex-col md:flex-row" style="content-visibility: auto">
  <div class="w-full md:w-1/2 bg-marrom-escuro p-10 md:p-16 flex flex-col justify-center min-h-[50vh] md:min-h-screen">
    <h2 class="text-4xl md:text-5xl font-bold text-bege leading-tight mb-10">
      Vantagens que<br/>o plástico não entrega.
    </h2>
    <ul class="space-y-6">
      {items.map((item) => (
        <li class="flex items-start gap-4 group">
          <span class="mt-2 w-3 h-3 rounded-full bg-bege shrink-0 transition-all duration-300 group-hover:scale-150 group-hover:bg-white" />
          <div>
            <span class="text-bege text-xl font-bold">{item.title}</span>
            <span class="text-bege/80 text-lg"> — {item.desc}</span>
          </div>
        </li>
      ))}
    </ul>
  </div>

  <div class="w-full md:w-1/2">
    <img
      src={imageSrc}
      alt={imageAlt}
      class="w-full h-[50vh] md:h-screen object-cover"
      loading="lazy"
      decoding="async"
    />
  </div>
</section>