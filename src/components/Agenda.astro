---
const eventos = [
  {
    data: '12–14 Jun',
    titulo: 'Feira de Artesanato da Praça',
    local: 'Praça Central, Centro',
    hora: '09h – 18h',
  },
  {
    data: '26–27 Jul',
    titulo: 'Mostra Cultural de Inverno',
    local: 'Centro Cultural Municipal',
    hora: '10h – 20h',
  },
  {
    data: '16 Ago',
    titulo: 'Bazar do Ateliê Ahois',
    local: 'Ateliê — Rua das Flores, 123',
    hora: '09h – 17h',
  },
]
---

<section class="bg-bege py-16 md:py-24 px-6 md:px-16" style="content-visibility: auto">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-marrom-escuro text-center mb-4">
      Agenda de Eventos
    </h2>
    <p class="text-marrom-escuro/70 text-center text-lg mb-12 max-w-lg mx-auto">
      Encontre a gente nas próximas feiras e mostras culturais.
    </p>

    <svg style="display:none">
      <defs>
        <g id="icon-pin">
          <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </g>
        <g id="icon-clock">
          <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </g>
      </defs>
    </svg>

    <div class="grid md:grid-cols-3 gap-6 mb-14">
      {eventos.map((e) => (
        <div class="bg-white rounded-2xl p-6 shadow-md flex flex-col gap-3">
          <span class="text-sm font-bold text-marrom-claro tracking-wide uppercase">{e.data}</span>
          <h3 class="text-xl font-bold text-marrom-escuro leading-tight">{e.titulo}</h3>
          <div class="text-marrom-escuro/70 text-sm space-y-1">
            <p class="flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24"><use href="#icon-pin"/></svg>
              {e.local}
            </p>
            <p class="flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24"><use href="#icon-clock"/></svg>
              {e.hora}
            </p>
          </div>
        </div>
      ))}
    </div>

    <div class="rounded-2xl overflow-hidden shadow-lg">
      <iframe
        title="Localização das mostras culturais"
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1971.6954203214927!2d-63.87793610115205!3d-8.749246742218144!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x92325cad85c2a02f%3A0x383cf269b878ead1!2sEstacionamento%20-%20Flodoaldo%20Pontes%20Pinto%2C%20Porto%20Velho%20-%20RO!5e0!3m2!1spt-BR!2sbr!4v1780353873887!5m2!1spt-BR!2sbr" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
        width="100%"
        height="380"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="w-full"
      ></iframe>
    </div>

    <p class="text-marrom-escuro/70 text-center text-sm mt-6">
      Localmente em Porto Velho e enviando para todo o Brasil
    </p>
  </div>
</section>
